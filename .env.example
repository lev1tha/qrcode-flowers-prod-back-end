# Скопируй в Railway как Environment Variables

SECRET_KEY=замени-на-случайную-строку-минимум-50-символов
DEBUG=False
ALLOWED_HOSTS=your-app.railway.app

# URL твоего Vercel фронтенда
CORS_ALLOWED_ORIGINS=https://qr-card-snowy.vercel.app

# Суперадмин
SUPERADMIN_LOGIN=admin
SUPERADMIN_PASSWORD=придумай-надёжный-пароль
SUPERADMIN_TOKEN=придумай-случайный-токен-32-символа

# Cloudinary — хранилище загруженных видео в проде (данные из дашборда Cloudinary).
# Если пусто — видео сохраняются на локальный диск (для разработки).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
