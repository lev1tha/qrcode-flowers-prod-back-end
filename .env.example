# Скопируй в .env и заполни реальными значениями (файл .env в git НЕ коммитится).

# ── Django ────────────────────────────────────────────────
SECRET_KEY=замени-на-случайную-строку-минимум-50-символов
DEBUG=False
# Обе A-записи (@ и www). www редиректится на корень nginx'ом, но хост указываем для запаса.
ALLOWED_HOSTS=example.com,www.example.com
# Домены для CSRF (Django admin по HTTPS)
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com
# Same-origin (/api на том же домене) — CORS не обязателен, но оставим согласованным
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ── PostgreSQL ────────────────────────────────────────────
# HOST=db — имя сервиса в docker-compose. Для локального запуска вне Docker — localhost.
POSTGRES_DB=qrcard
POSTGRES_USER=qrcard
POSTGRES_PASSWORD=замени-на-надёжный-пароль
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Панель суперадмина ────────────────────────────────────
SUPERADMIN_LOGIN=admin
SUPERADMIN_PASSWORD=придумай-надёжный-пароль
SUPERADMIN_TOKEN=придумай-случайный-токен-32-символа

# ── Seed (только первичный bootstrap) ─────────────────────
# RUN_SEED=1 включает наполнение стартовыми данными при старте контейнера.
RUN_SEED=0
MASTER_PASSWORD=пароль-мастер-кассира
DEMO_PASSWORD=пароль-демо-кассира
